<%= form_with(model: video_project, class: "form-container") do |form| %>
  <h1><%= video_project.new_record? ? "New Video Project" : "Edit Video Project" %></h1>

  <% if video_project.errors.any? %>
    <div style="color: #ef4444; background: rgba(239, 68, 68, 0.1); padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem;">
      <h3 style="margin-top: 0;"><%= pluralize(video_project.errors.count, "error") %> prohibited this project from being saved:</h3>
      <ul style="margin-bottom: 0;">
        <% video_project.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :title %>
    <%= form.text_field :title, class: "form-control", placeholder: "e.g. Mechanical Keyboard Review" %>
  </div>

  <div class="form-group">
    <%= form.label :status %>
    <%= form.select :status, VideoProject::STATUSES, {}, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :target_date %>
    <%= form.date_field :target_date, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :category %>
    <%= form.text_field :category, class: "form-control", placeholder: "e.g. Hardware" %>
  </div>

  <div style="margin-top: 2rem;">
    <%= form.submit "Save Project", class: "btn btn-primary", style: "width: 100%;" %>
  </div>
<% end %>
